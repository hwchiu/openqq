{
  "version": 1,
  "stacks": [
    {
      "id": "k3s-gvisor",
      "title": "K3s + gVisor",
      "family": "baseline",
      "runtime": "gvisor",
      "controlPlane": "none",
      "installScript": "./scripts/install-k3s-gvisor.sh",
      "runbook": "docs/runbooks/install-k3s-gvisor.md"
    },
    {
      "id": "k3s-openshell-runc",
      "title": "K3s + OpenShell + runc",
      "family": "openshell",
      "runtime": "runc",
      "controlPlane": "openshell",
      "installScript": "./scripts/install-k3s-openshell-runc.sh",
      "runbook": "docs/runbooks/install-k3s-openshell-runc.md"
    },
    {
      "id": "k3s-openshell-gvisor",
      "title": "K3s + OpenShell + gVisor",
      "family": "openshell",
      "runtime": "gvisor",
      "controlPlane": "openshell",
      "installScript": "./scripts/install-k3s-openshell-gvisor.sh",
      "runbook": "docs/runbooks/install-k3s-openshell-gvisor.md"
    },
    {
      "id": "k3s-kubearmor-runc",
      "title": "K3s + KubeArmor + runc",
      "family": "kubearmor",
      "runtime": "runc",
      "controlPlane": "kubearmor",
      "installScript": "./scripts/install-k3s-kubearmor-runc.sh",
      "runbook": "docs/runbooks/install-k3s-kubearmor-runc.md"
    }
  ],
  "tests": [
    {
      "id": "nodes-ready",
      "title": "Three nodes Ready",
      "category": "baseline",
      "runner": "scripts/tests/nodes-ready.sh",
      "appliesTo": ["all"],
      "goal": "確認三節點叢集基線可用"
    },
    {
      "id": "baseline-pod",
      "title": "Baseline pod execution",
      "category": "baseline",
      "runner": "scripts/tests/baseline-pod.sh",
      "appliesTo": ["all"],
      "goal": "確認叢集能建立最小工作負載"
    },
    {
      "id": "gvisor-runtime",
      "title": "gVisor RuntimeClass probe",
      "category": "runtime",
      "runner": "scripts/tests/gvisor-runtime.sh",
      "appliesTo": ["k3s-gvisor", "k3s-openshell-gvisor"],
      "goal": "驗證 runsc 真的在執行，而不是只有 YAML 存在"
    },
    {
      "id": "openshell-control-plane",
      "title": "OpenShell control plane ready",
      "category": "control-plane",
      "runner": "scripts/tests/openshell-control-plane.sh",
      "appliesTo": ["k3s-openshell-runc", "k3s-openshell-gvisor"],
      "goal": "確認 agent-sandbox 與 OpenShell gateway 已穩定"
    },
    {
      "id": "openshell-guardrails",
      "title": "OpenShell guardrails",
      "category": "security",
      "runner": "scripts/tests/openshell-guardrails.sh",
      "appliesTo": ["k3s-openshell-runc", "k3s-openshell-gvisor"],
      "goal": "測試 egress / L7 / filesystem policy 是否成立或退化"
    },
    {
      "id": "kubearmor-sa-block",
      "title": "KubeArmor blocks SA token read",
      "category": "security",
      "runner": "scripts/tests/kubearmor-sa-block.sh",
      "appliesTo": ["k3s-kubearmor-runc"],
      "goal": "確認 KubeArmor policy 確實阻擋 service account token"
    }
  ]
}
