# Azure target selection
export AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
export AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"
export AZURE_REGION="eastus"

# Authentication mode
# Supported values for the current scaffold:
# - mcp
# - cli
export AZURE_ACCESS_MODE="mcp"

# Optional: set this to the expected Azure MCP server name if your runtime exposes one.
export AZURE_MCP_SERVER=""

# CLI fallback variables
export AZURE_CLIENT_ID=""
export AZURE_CLIENT_SECRET=""

# Optional environment naming
export ENVIRONMENT_NAME="lab"

# Cluster layout
export CLUSTER_NAME="azure-k3s-lab"
export AZURE_RESOURCE_GROUP="rg-azure-k3s-lab"
export AZURE_VM_SIZE="Standard_B2s"
export AZURE_NODE_COUNT="3"
export AZURE_ADMIN_USERNAME="azureuser"
export AZURE_SSH_PUBLIC_KEY_PATH="$HOME/.ssh/id_ed25519.pub"

# Networking
export AZURE_VNET_NAME="vnet-azure-k3s-lab"
export AZURE_SUBNET_NAME="snet-k3s"
export AZURE_NSG_NAME="nsg-azure-k3s-lab"
export AZURE_VNET_CIDR="10.100.0.0/16"
export AZURE_SUBNET_CIDR="10.100.0.0/24"
export K3S_CLUSTER_CIDR="10.42.0.0/16"
export K3S_SERVICE_CIDR="10.43.0.0/16"

# Node names
export CONTROL_PLANE_NAME="cp-0"
export WORKER1_NAME="worker-1"
export WORKER2_NAME="worker-2"
